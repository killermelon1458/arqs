ARQS_APP_NAME=arqs-server
ARQS_APP_VERSION=1.0.0-v1
ARQS_HOST=0.0.0.0
ARQS_PORT=8080
ARQS_DATABASE_PATH=/data/arqs.db
ARQS_ADMIN_API_KEY=change-me-admin-key
ARQS_PUBLIC_REGISTRATION_ENABLED=true
ARQS_LINK_CODE_TTL_SECONDS=300
ARQS_ADAPTER_PROVISION_TTL_SECONDS=600
ARQS_PACKET_ID_TTL_SECONDS=604800
ARQS_INBOX_POLL_INTERVAL_SECONDS=1.0
ARQS_LOG_LEVEL=INFO
ARQS_ENABLE_SQL_TRACE=false
ARQS_REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
ARQS_REGISTER_RATE_LIMIT_MAX_ATTEMPTS=20
ARQS_TRUST_PROXY_HEADERS=false
ARQS_TRUST_PROXY_CIDRS=
ARQS_TRUST_PROXY_IPS=
